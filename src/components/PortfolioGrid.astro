---
import PortfolioCard from "./PortfolioCard.astro";

const { projects } = Astro.props;
---

<div class="project-grid" id="portfolio-grid">
    {
        projects.map((p: any) => (
            <div
                class="portfolio-card-wrapper"
                data-title={p.data.title.toLowerCase()}
                data-tags={JSON.stringify(p.data.tags || [])}
                data-date={p.data.pubDate.valueOf()}
            >
                <PortfolioCard project={p} />
            </div>
        ))
    }
</div>

<style>
    /* ═══ GRID ═══ */
    .project-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 1.25rem;
    }
</style>
