---
// src/components/SkillsMatrix.astro
// Dashboard-style skills display with category cards

interface Skill {
    name: string;
    level: number; // 0-100
}

interface Category {
    title: string;
    icon: string;
    skills: Skill[];
}

const categories: Category[] = [
    {
        title: "AI & Machine Learning",
        icon: "🧠",
        skills: [
            { name: "LLMs / RAG", level: 90 },
            { name: "TensorFlow / PyTorch", level: 75 },
            { name: "Computer Vision", level: 65 },
            { name: "NLP", level: 80 },
        ],
    },
    {
        title: "Data Engineering",
        icon: "📊",
        skills: [
            { name: "Python / Pandas", level: 95 },
            { name: "SQL / ETL", level: 90 },
            { name: "Apache Spark", level: 70 },
            { name: "Data Modeling", level: 85 },
        ],
    },
    {
        title: "Cloud & DevOps",
        icon: "☁️",
        skills: [
            { name: "Cloudflare Workers", level: 90 },
            { name: "Docker / K8s", level: 80 },
            { name: "CI/CD Pipelines", level: 75 },
            { name: "IaC (Terraform)", level: 65 },
        ],
    },
    {
        title: "Development",
        icon: "⚡",
        skills: [
            { name: "TypeScript / Node", level: 90 },
            { name: "Rust", level: 55 },
            { name: "Astro / React", level: 85 },
            { name: "APIs REST/GraphQL", level: 88 },
        ],
    },
];
---

<div class="skills-dashboard">
    {
        categories.map((cat) => (
            <div class="skill-card">
                <div class="skill-card-header">
                    <span class="skill-icon">{cat.icon}</span>
                    <h3 class="skill-category">{cat.title}</h3>
                </div>
                <div class="skill-bars">
                    {cat.skills.map((skill) => (
                        <div class="skill-row">
                            <div class="skill-info">
                                <span class="skill-name">{skill.name}</span>
                                <span class="skill-pct">{skill.level}%</span>
                            </div>
                            <div class="skill-track">
                                <div
                                    class="skill-fill"
                                    style={`--target-width: ${skill.level}%`}
                                />
                            </div>
                        </div>
                    ))}
                </div>
            </div>
        ))
    }
</div>

<style>
    .skills-dashboard {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 1rem;
        width: 100%;
    }

    .skill-card {
        background: var(--surface);
        border: 1px solid var(--gray-light);
        border-radius: 14px;
        padding: 1.25rem;
        box-shadow: var(--box-shadow);
        transition: all 0.3s ease;
    }

    .skill-card:hover {
        border-color: color-mix(in srgb, var(--primary) 30%, transparent);
        transform: translateY(-2px);
    }

    .skill-card-header {
        display: flex;
        align-items: center;
        gap: 0.6rem;
        margin-bottom: 1rem;
    }

    .skill-icon {
        font-size: 1.3rem;
        width: 36px;
        height: 36px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: color-mix(in srgb, var(--primary) 10%, transparent);
        border-radius: 10px;
        border: 1px solid color-mix(in srgb, var(--primary) 15%, transparent);
    }

    .skill-category {
        font-family: "Fira Code", monospace;
        font-size: 0.82rem;
        font-weight: 700;
        margin: 0;
        color: var(--black);
    }

    .skill-bars {
        display: flex;
        flex-direction: column;
        gap: 0.65rem;
    }

    .skill-row {
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
    }

    .skill-info {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .skill-name {
        font-family: "Fira Code", monospace;
        font-size: 0.72rem;
        color: var(--gray);
    }

    .skill-pct {
        font-family: "Fira Code", monospace;
        font-size: 0.65rem;
        font-weight: 700;
        color: var(--primary);
    }

    .skill-track {
        width: 100%;
        height: 6px;
        background: color-mix(in srgb, var(--gray-light) 80%, transparent);
        border-radius: 3px;
        overflow: hidden;
    }

    .skill-fill {
        height: 100%;
        width: 0;
        border-radius: 3px;
        background: linear-gradient(
            90deg,
            var(--primary),
            color-mix(in srgb, var(--primary) 70%, var(--accent))
        );
        animation: fillBar 1.2s ease forwards;
        animation-delay: 0.5s;
    }

    @keyframes fillBar {
        to {
            width: var(--target-width);
        }
    }

    @media (max-width: 600px) {
        .skills-dashboard {
            grid-template-columns: 1fr;
        }
    }
</style>
