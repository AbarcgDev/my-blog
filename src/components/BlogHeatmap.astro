---
const { postsData } = Astro.props;
---

<section class="panel">
    <div class="panel-header">
        <span class="panel-dot"></span>
        <span class="panel-title">Actividad de publicación</span>
    </div>
    <div class="heatmap-scroll-wrapper">
        <div class="heatmap-months" id="heatmap-months"></div>
        <div class="heatmap-container" id="heatmap"></div>
    </div>
    <div class="heatmap-legend">
        <span class="legend-label">Menos</span>
        <span class="legend-cell" style="opacity:0.15"></span>
        <span class="legend-cell" style="opacity:0.35"></span>
        <span class="legend-cell" style="opacity:0.55"></span>
        <span class="legend-cell" style="opacity:0.8"></span>
        <span class="legend-cell" style="opacity:1"></span>
        <span class="legend-label">Más</span>
    </div>
</section>

<style>
    /* ═══════════ PANELS ═══════════ */
    .panel {
        background: var(--surface);
        border: 1px solid var(--gray-light);
        border-radius: 14px;
        padding: 1rem 1.2rem;
        box-shadow: var(--box-shadow);
    }

    .panel-header {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        margin-bottom: 0.8rem;
    }

    .panel-dot {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: var(--primary);
    }

    .panel-title {
        font-family: "Fira Code", monospace;
        font-size: 0.72rem;
        font-weight: 700;
        color: var(--black);
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    /* ═══════════ HEATMAP ═══════════ */
    .heatmap-scroll-wrapper {
        width: 100%;
        overflow-x: auto;
        padding-bottom: 0.5rem;
    }

    /* Custom thin scrollbar */
    .heatmap-scroll-wrapper::-webkit-scrollbar {
        height: 6px;
    }
    .heatmap-scroll-wrapper::-webkit-scrollbar-track {
        background: transparent;
    }
    .heatmap-scroll-wrapper::-webkit-scrollbar-thumb {
        background: color-mix(in srgb, var(--primary) 30%, transparent);
        border-radius: 3px;
    }

    .heatmap-months {
        display: grid;
        grid-template-columns: repeat(52, minmax(10px, 1fr));
        gap: 2px;
        margin-bottom: 2px;
        min-width: 600px;
    }

    .heatmap-months :global(.month-label) {
        font-family: "Fira Code", monospace;
        font-size: 0.65rem;
        color: var(--gray);
        text-transform: capitalize;
        white-space: nowrap;
        overflow: hidden;
    }

    .heatmap-container {
        display: grid;
        grid-template-columns: repeat(52, minmax(10px, 1fr));
        gap: 2px;
        padding: 0.2rem 0;
        min-width: 600px;
    }

    .heatmap-container :global(.hm-cell) {
        width: 100%;
        height: 12px;
        border-radius: 2px;
        background: var(--primary);
        opacity: 0.08;
        transition: opacity 0.2s ease;
    }

    .heatmap-legend {
        display: flex;
        align-items: center;
        gap: 3px;
        justify-content: flex-end;
        margin-top: 0.4rem;
    }

    .legend-label {
        font-family: "Fira Code", monospace;
        font-size: 0.55rem;
        color: var(--gray);
        margin: 0 3px;
    }

    .legend-cell {
        width: 10px;
        height: 10px;
        border-radius: 2px;
        background: var(--primary);
    }

    @media (max-width: 640px) {
        /* Remove previous grid adjustments, the scroll wrapper handles it smoothly now */
    }
</style>

<script define:vars={{ postsData }}>
    (() => {
        const container = document.getElementById("heatmap");
        const monthsContainer = document.getElementById("heatmap-months");
        if (!container) return;

        const posts = JSON.parse(postsData);
        const postDates = posts.map((p) =>
            new Date(p.pubDate).toISOString().slice(0, 10)
        );

        // Build 52 weeks × 7 days grid (last 364 days)
        const today = new Date();
        const cells = [];

        for (let w = 51; w >= 0; w--) {
            for (let d = 0; d < 7; d++) {
                const date = new Date(today);
                date.setDate(date.getDate() - (w * 7 + (6 - d)));
                const dateStr = date.toISOString().slice(0, 10);
                const count = postDates.filter((pd) => pd === dateStr).length;
                cells.push({ dateStr, count });
            }
        }

        // Only render 1 row of 52 (weekly summary)
        const weeklyData = [];
        for (let w = 0; w < 52; w++) {
            const weekCells = cells.slice(w * 7, (w + 1) * 7);
            const total = weekCells.reduce((s, c) => s + c.count, 0);
            weeklyData.push(total);
        }

        container.innerHTML = "";
        const maxCount = Math.max(1, ...weeklyData);

        const activeMonths = [];
        let currentMonth = -1;

        weeklyData.forEach((count, i) => {
            const weekStart = new Date(today);
            weekStart.setDate(weekStart.getDate() - (51 - i) * 7);

            // Month Label Logic
            const m = weekStart.getMonth();
            if (m !== currentMonth) {
                if (currentMonth !== -1) {
                    activeMonths[activeMonths.length - 1].span =
                        i - activeMonths[activeMonths.length - 1].start;
                }
                activeMonths.push({
                    month: weekStart.toLocaleDateString("es-MX", {
                        month: "short",
                    }),
                    start: i,
                    span: 0,
                });
                currentMonth = m;
            }

            // Cell Rendering
            const cell = document.createElement("div");
            cell.className = "hm-cell";
            if (count > 0) {
                cell.style.opacity = String(0.25 + (count / maxCount) * 0.75);
            }
            cell.title = `Semana del ${weekStart.toLocaleDateString("es-MX", {
                month: "short",
                day: "numeric",
            })}: ${count} post${count !== 1 ? "s" : ""}`;
            container.appendChild(cell);
        });

        // Close last span
        if (activeMonths.length > 0) {
            activeMonths[activeMonths.length - 1].span =
                52 - activeMonths[activeMonths.length - 1].start;
        }

        if (monthsContainer) {
            monthsContainer.innerHTML = "";
            activeMonths.forEach((am) => {
                const label = document.createElement("span");
                label.className = "month-label";
                label.textContent = am.month;
                label.style.gridColumn = `${am.start + 1} / span ${am.span}`;
                monthsContainer.appendChild(label);
            });
        }
    })();
</script>
