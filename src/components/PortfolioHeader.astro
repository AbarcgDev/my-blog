---
const { totalProjects, healthyCount, totalStars, langsCount } = Astro.props;
---

<section class="obs-header">
    <div class="obs-header-left">
        <h1>
            <span class="status-pulse"></span>
            Portafolio
        </h1>
        <p class="obs-subtitle">
            Production metrics & health — synced from GitHub
        </p>
    </div>
    <!-- Stats moved to sidebar -->
</section>

<style>
    /* ═══ HEADER ═══ */
    .obs-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
        gap: 1rem;
        background: var(--background);
        padding: 1rem 0 1.5rem 0;
        margin-top: -1rem;
    }

    .obs-header h1 {
        font-family: "Fira Code", monospace;
        font-size: 1.5rem;
        font-weight: 800;
        color: var(--black);
        margin: 0;
        display: flex;
        align-items: center;
        gap: 0.6rem;
    }

    .status-pulse {
        width: 10px;
        height: 10px;
        border-radius: 50%;
        background: #22c55e;
        box-shadow: 0 0 0 0 rgba(34, 197, 94, 0.4);
        animation: pulse 2s ease-in-out infinite;
    }

    @keyframes pulse {
        0%,
        100% {
            box-shadow: 0 0 0 0 rgba(34, 197, 94, 0.4);
        }
        50% {
            box-shadow: 0 0 0 6px rgba(34, 197, 94, 0);
        }
    }

    .obs-subtitle {
        font-family: "Fira Code", monospace;
        font-size: 0.68rem;
        color: var(--gray);
        margin: 0.2rem 0 0 0;
    }

    /* Stats styles moved to sidebar */

    @media (max-width: 640px) {
        .obs-header {
            flex-direction: column;
            align-items: flex-start;
        }
    }
</style>
