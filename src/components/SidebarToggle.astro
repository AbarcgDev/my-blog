---
// SidebarToggle.astro
// A floating button that toggles sidebar visibility on mobile.
// Works with any sidebar using the class `.collapsible-sidebar`.
---

<button
    class="sidebar-toggle"
    id="sidebar-toggle"
    aria-label="Mostrar/ocultar barra lateral"
>
    <svg
        class="icon-open"
        viewBox="0 0 24 24"
        width="20"
        height="20"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
    >
        <rect x="3" y="3" width="7" height="18" rx="1"></rect>
        <line x1="14" y1="6" x2="21" y2="6"></line>
        <line x1="14" y1="12" x2="21" y2="12"></line>
        <line x1="14" y1="18" x2="21" y2="18"></line>
    </svg>
    <svg
        class="icon-close"
        viewBox="0 0 24 24"
        width="20"
        height="20"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
    >
        <line x1="18" y1="6" x2="6" y2="18"></line>
        <line x1="6" y1="6" x2="18" y2="18"></line>
    </svg>
</button>

<style>
    .sidebar-toggle {
        display: none; /* Hidden on desktop */
        position: fixed;
        bottom: 1.5rem;
        left: 1.5rem;
        z-index: 1000;
        width: 48px;
        height: 48px;
        border-radius: 50%;
        border: 1px solid var(--gray-light);
        background: var(--surface);
        color: var(--black);
        box-shadow: 0 4px 16px rgba(0, 0, 0, 0.15);
        cursor: pointer;
        align-items: center;
        justify-content: center;
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

    .sidebar-toggle:hover {
        transform: scale(1.08);
        box-shadow: 0 6px 20px rgba(0, 0, 0, 0.2);
    }

    .sidebar-toggle .icon-close {
        display: none;
    }

    :global(.sidebar-open) .sidebar-toggle .icon-open {
        display: none;
    }
    :global(.sidebar-open) .sidebar-toggle .icon-close {
        display: block;
    }

    @media (max-width: 900px) {
        .sidebar-toggle {
            display: flex;
        }
    }
</style>

<script>
    document.addEventListener("DOMContentLoaded", () => {
        const btn = document.getElementById("sidebar-toggle");
        if (!btn) return;

        btn.addEventListener("click", () => {
            document.body.classList.toggle("sidebar-open");
        });
    });
</script>
