---
// TocToggle.astro
// A floating button on the right side that toggles the Table of Contents sidebar.
---

<button class="toc-toggle" id="toc-toggle" aria-label="Mostrar/ocultar índice">
    <svg
        class="icon-open"
        viewBox="0 0 24 24"
        width="20"
        height="20"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
    >
        <line x1="3" y1="6" x2="15" y2="6"></line>
        <line x1="3" y1="12" x2="21" y2="12"></line>
        <line x1="3" y1="18" x2="18" y2="18"></line>
        <polyline points="15 3 18 6 15 9"></polyline>
    </svg>
    <svg
        class="icon-close"
        viewBox="0 0 24 24"
        width="20"
        height="20"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
    >
        <line x1="18" y1="6" x2="6" y2="18"></line>
        <line x1="6" y1="6" x2="18" y2="18"></line>
    </svg>
</button>

<style>
    .toc-toggle {
        display: none;
        position: fixed;
        bottom: 1.5rem;
        right: 1.5rem;
        z-index: 1000;
        width: 48px;
        height: 48px;
        border-radius: 50%;
        border: 1px solid var(--gray-light);
        background: var(--surface);
        color: var(--black);
        box-shadow: 0 4px 16px rgba(0, 0, 0, 0.15);
        cursor: pointer;
        align-items: center;
        justify-content: center;
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

    .toc-toggle:hover {
        transform: scale(1.08);
        box-shadow: 0 6px 20px rgba(0, 0, 0, 0.2);
    }

    .toc-toggle .icon-close {
        display: none;
    }

    :global(.toc-open) .toc-toggle .icon-open {
        display: none;
    }
    :global(.toc-open) .toc-toggle .icon-close {
        display: block;
    }

    @media (max-width: 1400px) {
        .toc-toggle {
            display: flex;
        }
    }
</style>

<script>
    document.addEventListener("DOMContentLoaded", () => {
        const btn = document.getElementById("toc-toggle");
        if (!btn) return;

        btn.addEventListener("click", () => {
            document.body.classList.toggle("toc-open");
            // Close left sidebar if open
            document.body.classList.remove("sidebar-open");
        });
    });
</script>
