---
// Importamos el formateador de fecha que ya viene en el template
import FormattedDate from './FormattedDate.astro';

interface Props {
    title: string;
    description: string;
    pubDate: Date;
    heroImage?: string;
    slug: string;
    tags?: string[];
}

const { title, description, pubDate, heroImage, slug, tags = [] } = Astro.props;
---

<a href={`/blog/${slug}/`} class="blog-card">
    {heroImage && (
        <div class="image-container">
            <img src={heroImage} alt="" loading="lazy" />
            {tags.length > 0 && (
                <div class="tags-overlay">
                    {tags.slice(0, 2).map(tag => <span>{tag}</span>)}
                </div>
            )}
        </div>
    )}
    <div class="content">
        <header>
            <p class="date">
                <FormattedDate date={pubDate} />
            </p>
            <h3 class="title">{title}</h3>
        </header>
        <p class="description">{description}</p>
        <footer class="read-more">
            Leer artículo <i class="nf-md-arrow_right"></i>
        </footer>
    </div>
</a>

<style>
    .blog-card {
        display: flex;
        flex-direction: column;
        background: var(--background);
        border: 1px solid var(--gray-light);
        border-radius: 12px;
        overflow: hidden;
        text-decoration: none;
        color: var(--black);
        box-shadow: var(--box-shadow);
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        height: 100%;
    }

    .blog-card:hover {
        transform: translateY(-4px);
        border-color: var(--primary);
        box-shadow: 0 12px 20px -10px color-mix(in srgb, var(--gray-light), transparent 50%);
    }

    .image-container {
        position: relative;
        width: 100%;
        height: 180px;
        overflow: hidden;
        background: var(--gray-dark); /* Fallback por si no carga la imagen */
    }

    .image-container img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.5s ease;
    }

    .blog-card:hover img {
        transform: scale(1.05);
    }

    .tags-overlay {
        position: absolute;
        bottom: 8px;
        left: 8px;
        display: flex;
        gap: 4px;
    }

    .tags-overlay span {
        background: rgba(0, 0, 0, 0.6);
        backdrop-filter: blur(4px);
        color: white;
        font-size: 0.7rem;
        padding: 2px 8px;
        border-radius: 4px;
        text-transform: uppercase;
        border: 1px solid rgba(255, 255, 255, 0.2);
    }

    .content {
        padding: 1.25rem;
        display: flex;
        flex-direction: column;
        flex-grow: 1;
    }

    .date {
        font-size: 0.85rem;
        color: var(--gray);
        margin: 0;
    }

    .title {
        font-size: 1.35rem;
        margin: 0.5rem 0;
        line-height: 1.2;
        color: var(--black);
        /* Limitamos a 2 líneas para que no se rompa el grid */
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .description {
        font-size: 0.95rem;
        line-height: 1.5;
        color: var(--gray);
        margin-bottom: 1.5rem;
        flex-grow: 1;
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .read-more {
        font-size: 0.9rem;
        font-weight: 700;
        color: var(--primary);
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    /* Ajuste para el icono si lo usas */
    .read-more i {
        transition: transform 0.2s ease;
    }

    .blog-card:hover .read-more i {
        transform: translateX(4px);
    }
</style>
