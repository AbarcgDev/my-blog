---
import { Icon } from "astro-icon/components";
import { getLangIcon, getTechIcon } from "../utils/techIcons";

const { project } = Astro.props;
---

<article class="project-card">
    <a
        href={`/portfolio/${project.id}/`}
        class="full-card-link"
        aria-label={`Ver proyecto: ${project.data.title}`}></a>
    {/* ── Status bar ── */}
    <div class="status-bar">
        <div class="status-left">
            <span class={`health-dot ${project.health}`}></span>
            <span class={`health-label ${project.health}`}>
                {project.healthLabel}
            </span>
        </div>
        <span class="uptime-val">
            uptime <strong>{project.uptime}</strong>
        </span>
    </div>

    {/* ── Title ── */}
    <div class="card-title-row">
        <span class="lang-glyph">
            <Icon name={getLangIcon(project.data.language || "default")} />
        </span>
        <div class="title-content">
            <h2 class="card-name">
                {project.data.title}
            </h2>
            <p class="card-desc">
                {project.data.description}
            </p>
            {/* ── Stack tags ── */}
            {
                project.data.tags.length > 0 && (
                    <div class="stack-row">
                        {project.data.tags.map((tag: string) => (
                            <span class="tech-tag" title={tag}>
                                <Icon name={getTechIcon(tag)} />
                            </span>
                        ))}
                    </div>
                )
            }
        </div>
        <div class="card-actions">
            <a
                href={project.data.repoUrl}
                target="_blank"
                rel="noopener"
                class="action-link repo-link"
                title="Repository"
            >
                <Icon name="mdi:github" />
            </a>
            <a
                href={`/portfolio/${project.id}/`}
                class="action-link detail-link"
                title="Ver detalle"
            >
                <Icon name="mdi:arrow-right" />
            </a>
        </div>
    </div>

    {/* ── Metrics grid ── */}
    <div class="metrics-grid">
        <div class="metric-box" title="Stars">
            <span class="mb-val">{project.data.stars}</span>
            <span class="mb-label">
                <Icon name="mdi:star" />
            </span>
        </div>
        <div class="metric-box" title="Edad">
            <span class="mb-val">{project.ageMonths}m</span>
            <span class="mb-label">
                <Icon name="mdi:calendar" />
            </span>
        </div>
        <div class="metric-box" title="Último push">
            <span class="mb-val">{project.daysSinceUpdate}d</span>
            <span class="mb-label">
                <Icon name="mdi:source-commit" />
            </span>
        </div>
        <div class="metric-box" title="Dependencias">
            <span class="mb-val">{project.data.tags.length}</span>
            <span class="mb-label">
                <Icon name="mdi:package-variant" />
            </span>
        </div>
    </div>
</article>

<style>
    /* ═══ CARD ═══ */
    .project-card {
        position: relative;
        background: var(--surface);
        border: 1px solid var(--gray-light);
        border-radius: 14px;
        overflow: hidden;
        box-shadow: var(--box-shadow);
        transition: border-color 0.3s ease;
    }

    .project-card:hover {
        border-color: var(--primary);
    }

    /* ── Status bar ── */
    .status-bar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 0.5rem 1.2rem;
        background: color-mix(in srgb, var(--gray-light) 30%, transparent);
        border-bottom: 1px solid var(--gray-light);
    }

    .status-left {
        display: flex;
        align-items: center;
        gap: 0.4rem;
    }

    .health-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
    }

    .health-dot.green {
        background: #22c55e;
        box-shadow: 0 0 4px rgba(34, 197, 94, 0.5);
    }
    .health-dot.yellow {
        background: #eab308;
        box-shadow: 0 0 4px rgba(234, 179, 8, 0.5);
    }
    .health-dot.red {
        background: #ef4444;
        box-shadow: 0 0 4px rgba(239, 68, 68, 0.5);
    }

    .health-label {
        font-family: "Fira Code", monospace;
        font-size: 0.6rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.06em;
    }

    .health-label.green {
        color: #22c55e;
    }
    .health-label.yellow {
        color: #eab308;
    }
    .health-label.red {
        color: #ef4444;
    }

    .uptime-val {
        font-family: "Fira Code", monospace;
        font-size: 0.6rem;
        color: var(--gray);
    }

    .uptime-val strong {
        color: var(--primary);
    }

    /* ── Title ── */
    .card-title-row {
        display: flex;
        align-items: flex-start;
        gap: 0.8rem;
        padding: 1rem 1.2rem 0;
    }

    .lang-glyph {
        font-size: 2.2rem;
        color: var(--primary);
        flex-shrink: 0;
        margin-top: 0.1rem;
    }

    .card-name {
        font-family: "Fira Code", monospace;
        font-size: 1.05rem;
        font-weight: 700;
        color: var(--black);
        margin: 0;
        line-height: 1.3;
    }

    .full-card-link {
        position: absolute;
        inset: 0;
        z-index: 1;
        outline: none;
    }

    .card-desc {
        font-size: 0.78rem;
        color: var(--gray);
        margin: 0.2rem 0 0 0;
        line-height: 1.4;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    /* ── Metrics grid ── */
    .metrics-grid {
        display: flex;
        flex-wrap: wrap;
        gap: 0.6rem;
        padding: 0.6rem 1.2rem;
    }

    .metric-box {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        padding: 0.25rem 0.6rem;
        border-radius: 6px;
        background: color-mix(in srgb, var(--primary) 6%, transparent);
        border: 1px solid color-mix(in srgb, var(--primary) 12%, transparent);
    }

    .mb-val {
        font-family: "Fira Code", monospace;
        font-size: 0.75rem;
        font-weight: 700;
        color: var(--black);
        line-height: 1;
    }

    .mb-label {
        display: flex;
        align-items: center;
    }

    .mb-label [data-icon] {
        font-size: 1rem;
        color: var(--primary);
    }

    /* ── Stack ── */
    .stack-row {
        display: flex;
        gap: 0.6rem;
        flex-wrap: wrap;
        margin-top: 0.8rem;
    }

    .tech-tag {
        position: relative;
        z-index: 2;
        font-size: 0;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        transition: transform 0.2s ease;
    }

    .tech-tag:hover {
        transform: translateY(-2px);
    }

    .tech-tag [data-icon] {
        font-size: 1.5rem;
    }

    .title-content {
        flex: 1;
        min-width: 0;
    }

    /* ── Actions ── */
    .card-actions {
        position: relative;
        z-index: 2;
        display: flex;
        gap: 0.4rem;
        align-items: center;
    }

    .action-link {
        font-size: 0;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 0.2rem;
        transition: color 0.2s ease, transform 0.2s ease;
    }

    .action-link [data-icon] {
        font-size: 1.5rem;
    }

    .repo-link {
        color: var(--gray);
    }
    .repo-link:hover {
        color: var(--primary);
        transform: scale(1.1);
    }
    .detail-link {
        color: var(--primary);
    }
    .detail-link:hover {
        color: var(--accent);
        transform: translateX(2px);
    }

    @media (max-width: 640px) {
        .metrics-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }
</style>
