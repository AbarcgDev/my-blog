---
// src/components/ProjectBentoGrid.astro
// Cuadrícula asimétrica tipo Bento para proyectos desde la colección de contenido.
import { getCollection } from 'astro:content';

const allProjects = (await getCollection('projects')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

// Map languages to emojis for icons
const langIcons: Record<string, string> = {
  'TypeScript': '🔷',
  'JavaScript': '🟨',
  'Python': '🐍',
  'Java': '☕',
  'Rust': '🦀',
  'Go': '🐹',
  'Astro': '🚀',
  'N/A': '📦',
};

// Assign grid sizes based on position (first = large, etc.)
const spanPattern = ['large', 'tall', 'wide', 'normal', 'normal'] as const;
type Span = typeof spanPattern[number];

const projects = allProjects.map((project, i) => ({
  title: project.data.title,
  description: project.data.description,
  tags: project.data.tags.slice(0, 4),
  icon: langIcons[project.data.language || 'N/A'] || '📦',
  href: `/portfolio/${project.id}/`,
  span: (spanPattern[i % spanPattern.length]) as Span,
  stars: project.data.stars,
  language: project.data.language,
}));
---

{projects.length === 0 ? (
  <div class="empty-state">
    <p>No hay proyectos aún. Ejecuta <code>npm run sync:projects</code> para obtenerlos de GitHub.</p>
  </div>
) : (
  <div class="bento-grid">
    {projects.map((project) => (
      <a
        href={project.href}
        class={`bento-card bento-${project.span}`}
      >
        <!-- Icon badge -->
        <div class="card-header">
          <div class="card-icon">
            <span>{project.icon}</span>
          </div>
          {project.stars > 0 && (
            <span class="card-stars">⭐ {project.stars}</span>
          )}
        </div>

        <!-- Content -->
        <div class="card-content">
          <h3 class="card-title">{project.title}</h3>
          <p class="card-description">{project.description}</p>
        </div>

        <!-- Tags -->
        <div class="card-tags">
          {project.language && project.language !== 'N/A' && (
            <span class="tag tag-lang">{project.language}</span>
          )}
          {project.tags
            .filter((t) => t !== project.language)
            .map((tag) => (
              <span class="tag">{tag}</span>
            ))}
        </div>

        <!-- Decorative corner glow -->
        <div class="card-glow"></div>
      </a>
    ))}
  </div>
)}

<style>
  /* ========== EMPTY STATE ========== */
  .empty-state {
    text-align: center;
    padding: 3rem;
    color: var(--gray);
    font-family: 'Fira Code', monospace;
    border: 2px dashed var(--gray-light);
    border-radius: 16px;
  }

  .empty-state code {
    background: var(--gray-light);
    padding: 2px 8px;
    border-radius: 4px;
    font-size: 0.85em;
  }

  /* ========== BENTO GRID LAYOUT ========== */
  .bento-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    grid-auto-rows: minmax(180px, auto);
    gap: 1rem;
    width: 100%;
  }

  /* Span variants */
  .bento-large {
    grid-column: span 2;
    grid-row: span 2;
  }

  .bento-tall {
    grid-column: span 1;
    grid-row: span 2;
  }

  .bento-wide {
    grid-column: span 2;
    grid-row: span 1;
  }

  .bento-normal {
    grid-column: span 1;
    grid-row: span 1;
  }

  /* ========== CARD BASE ========== */
  .bento-card {
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: 1.5rem;
    background: var(--surface);
    border: 1px solid var(--gray-light);
    border-radius: 16px;
    text-decoration: none;
    color: var(--black);
    overflow: hidden;
    transition: all 0.35s cubic-bezier(0.4, 0, 0.2, 1);
    box-shadow: var(--box-shadow);
  }

  .bento-card:hover {
    transform: translateY(-4px);
    border-color: var(--primary);
    box-shadow:
      0 20px 40px -15px color-mix(in srgb, var(--primary) 15%, transparent),
      0 0 0 1px color-mix(in srgb, var(--primary) 30%, transparent);
  }

  /* ========== HEADER (icon + stars) ========== */
  .card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.75rem;
  }

  .card-icon {
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: color-mix(in srgb, var(--primary) 12%, transparent);
    border: 1px solid color-mix(in srgb, var(--primary) 20%, transparent);
    border-radius: 12px;
    font-size: 1.4rem;
    transition: all 0.3s ease;
  }

  .bento-card:hover .card-icon {
    background: color-mix(in srgb, var(--primary) 22%, transparent);
    transform: scale(1.08);
  }

  .card-stars {
    font-family: 'Fira Code', monospace;
    font-size: 0.75rem;
    color: var(--gray);
    background: color-mix(in srgb, var(--accent) 8%, transparent);
    padding: 2px 8px;
    border-radius: 8px;
    border: 1px solid color-mix(in srgb, var(--accent) 15%, transparent);
  }

  /* ========== CONTENT ========== */
  .card-content {
    flex: 1;
  }

  .card-title {
    font-family: 'Fira Code', monospace;
    font-size: 1.1rem;
    font-weight: 700;
    margin: 0 0 0.5rem 0;
    color: var(--black);
    line-height: 1.3;
  }

  .bento-large .card-title {
    font-size: 1.4rem;
  }

  .card-description {
    font-size: 0.85rem;
    line-height: 1.55;
    color: var(--gray);
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .bento-large .card-description {
    -webkit-line-clamp: 5;
    font-size: 0.9rem;
  }

  .bento-tall .card-description {
    -webkit-line-clamp: 5;
  }

  /* ========== TAGS ========== */
  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-top: 1rem;
  }

  .tag {
    font-family: 'Fira Code', monospace;
    font-size: 0.65rem;
    font-weight: 600;
    padding: 3px 10px;
    border-radius: 6px;
    background: color-mix(in srgb, var(--primary) 10%, transparent);
    color: var(--primary-dark);
    border: 1px solid color-mix(in srgb, var(--primary) 15%, transparent);
    letter-spacing: 0.03em;
    text-transform: uppercase;
    transition: all 0.2s ease;
  }

  .tag-lang {
    background: color-mix(in srgb, var(--accent) 12%, transparent);
    color: var(--accent);
    border-color: color-mix(in srgb, var(--accent) 20%, transparent);
  }

  @media (prefers-color-scheme: dark) {
    .tag {
      color: var(--primary);
    }
    .tag-lang {
      color: var(--accent-light, var(--accent));
    }
  }

  .bento-card:hover .tag {
    background: color-mix(in srgb, var(--primary) 18%, transparent);
    border-color: color-mix(in srgb, var(--primary) 30%, transparent);
  }

  /* ========== DECORATIVE GLOW ========== */
  .card-glow {
    position: absolute;
    top: -40%;
    right: -30%;
    width: 200px;
    height: 200px;
    background: radial-gradient(
      circle,
      color-mix(in srgb, var(--primary) 8%, transparent),
      transparent 70%
    );
    border-radius: 50%;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.4s ease;
  }

  .bento-card:hover .card-glow {
    opacity: 1;
  }

  /* ========== RESPONSIVE ========== */
  @media (max-width: 900px) {
    .bento-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .bento-large {
      grid-column: span 2;
      grid-row: span 1;
    }

    .bento-tall {
      grid-column: span 1;
      grid-row: span 1;
    }

    .bento-wide {
      grid-column: span 2;
    }
  }

  @media (max-width: 520px) {
    .bento-grid {
      grid-template-columns: 1fr;
      grid-auto-rows: auto;
    }

    .bento-large,
    .bento-tall,
    .bento-wide,
    .bento-normal {
      grid-column: span 1;
      grid-row: span 1;
    }

    .bento-card {
      padding: 1.2rem;
    }
  }
</style>
