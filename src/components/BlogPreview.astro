---
import { Icon } from "astro-icon/components";
---

<!-- ═══ HOVER PREVIEW ═══ -->
<div class="preview-panel" id="preview-panel">
    <div class="preview-header">
        <span class="preview-dot"></span>
        <span class="preview-title" id="preview-title">Quick View</span>
    </div>
    <p class="preview-desc" id="preview-desc"></p>
    <div class="preview-tags" id="preview-tags"></div>
    <div class="preview-metrics" id="preview-metrics">
        <div class="preview-metric">
            <span class="pm-label">Complejidad</span>
            <div class="pm-bar-track">
                <div class="pm-bar-fill" id="pm-complexity"></div>
            </div>
        </div>
        <div class="preview-metric">
            <span class="pm-label">Lectura</span>
            <span class="pm-value" id="pm-reading"></span>
        </div>
    </div>
    <a class="preview-go" id="preview-go" href="#" title="Leer artículo">
        <Icon name="mdi:arrow-right" />
    </a>
</div>

<style>
    /* ═══════════ PREVIEW PANEL ═══════════ */
    .preview-panel {
        position: fixed;
        z-index: 100;
        width: 320px;
        background: var(--surface);
        border: 1px solid var(--gray-light);
        border-radius: 12px;
        padding: 1rem 1.2rem;
        box-shadow: 0 20px 40px -10px rgba(0, 0, 0, 0.2),
            0 0 0 1px color-mix(in srgb, var(--primary) 8%, transparent);
        opacity: 0;
        visibility: hidden;
        transform: translateY(6px);
        transition: opacity 0.2s ease, transform 0.2s ease, visibility 0.2s ease;
        pointer-events: none;
    }

    .preview-panel.visible {
        opacity: 1;
        visibility: visible;
        transform: translateY(0);
        pointer-events: auto;
    }

    .preview-header {
        display: flex;
        align-items: center;
        gap: 0.4rem;
        margin-bottom: 0.5rem;
    }

    .preview-dot {
        width: 5px;
        height: 5px;
        border-radius: 50%;
        background: var(--accent);
    }

    .preview-title {
        font-family: "Fira Code", monospace;
        font-size: 0.78rem;
        font-weight: 700;
        color: var(--black);
        line-height: 1.3;
    }

    .preview-desc {
        font-size: 0.72rem;
        color: var(--gray);
        line-height: 1.5;
        margin: 0;
    }

    .preview-tags {
        display: flex;
        gap: 0.3rem;
        flex-wrap: wrap;
        margin-top: 0.6rem;
    }

    .preview-tags :global(.ptag) {
        font-family: "Fira Code", monospace;
        font-size: 0.55rem;
        padding: 0.12rem 0.4rem;
        border-radius: 4px;
        background: color-mix(in srgb, var(--primary) 10%, transparent);
        color: var(--primary);
        text-transform: uppercase;
    }

    .preview-metrics {
        display: flex;
        gap: 1rem;
        margin-top: 0.6rem;
        align-items: center;
    }

    .preview-metric {
        display: flex;
        align-items: center;
        gap: 0.4rem;
    }

    .pm-label {
        font-family: "Fira Code", monospace;
        font-size: 0.55rem;
        color: var(--gray);
        text-transform: uppercase;
    }

    .pm-bar-track {
        width: 50px;
        height: 4px;
        border-radius: 2px;
        background: color-mix(in srgb, var(--gray-light) 80%, transparent);
        overflow: hidden;
    }

    .pm-bar-fill {
        height: 100%;
        border-radius: 2px;
        background: var(--accent);
        transition: width 0.3s ease;
    }

    .pm-value {
        font-family: "Fira Code", monospace;
        font-size: 0.65rem;
        color: var(--primary);
        font-weight: 700;
    }

    .preview-go {
        display: block;
        margin-top: 0.7rem;
        font-size: 0;
        color: var(--primary);
        text-decoration: none;
        transition: color 0.2s ease, transform 0.2s ease;
    }

    .preview-go [data-icon] {
        font-size: 2rem;
    }

    .preview-go:hover {
        color: var(--accent);
    }

    @media (max-width: 640px) {
        .preview-panel {
            display: none;
        }
    }
</style>

<script>
    // ═══ HOVER PREVIEW ═══
    (() => {
        const preview = document.getElementById("preview-panel");
        const rows = document.querySelectorAll(".post-row");
        if (!preview || !rows.length) return;

        let hideTimeout: number;

        rows.forEach((row) => {
            row.addEventListener("mouseenter", (e) => {
                clearTimeout(hideTimeout);

                const titleElem = row.querySelector(".cell-title a");
                const title = titleElem ? titleElem.textContent : "";
                const desc = row.getAttribute("data-description") || "";
                const tags = JSON.parse(row.getAttribute("data-tags") || "[]");
                const complexity = parseFloat(
                    row.getAttribute("data-complexity") || "0"
                );
                const reading = row.getAttribute("data-reading") || "0";
                const slug = row.getAttribute("data-slug") || "";

                const titleNode = document.getElementById("preview-title");
                const descNode = document.getElementById("preview-desc");
                const tagsNode = document.getElementById("preview-tags");
                const pTagsNode = row.querySelector(".hidden-preview-tags");
                const compNode = document.getElementById("pm-complexity");
                const readNode = document.getElementById("pm-reading");
                const goNode = document.getElementById(
                    "preview-go"
                ) as HTMLAnchorElement;

                if (titleNode) titleNode.textContent = title;
                if (descNode) descNode.textContent = desc;
                if (tagsNode && pTagsNode)
                    tagsNode.innerHTML = pTagsNode.innerHTML;
                if (compNode) compNode.style.width = complexity * 100 + "%";
                if (readNode) readNode.textContent = reading + " min";
                if (goNode) goNode.href = `/blog/${slug}/`;

                // Position
                const rect = row.getBoundingClientRect();
                const pw = 320;
                const left = Math.min(
                    rect.right + 12,
                    window.innerWidth - pw - 20
                );
                const top = Math.max(10, rect.top - 20);

                preview.style.left = left + "px";
                preview.style.top = top + "px";
                preview.classList.add("visible");
            });

            row.addEventListener("mouseleave", () => {
                hideTimeout = window.setTimeout(() => {
                    preview.classList.remove("visible");
                }, 200);
            });
        });

        preview.addEventListener("mouseenter", () => clearTimeout(hideTimeout));
        preview.addEventListener("mouseleave", () => {
            preview.classList.remove("visible");
        });
    })();
</script>
