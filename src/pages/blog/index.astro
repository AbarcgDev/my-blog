---
import { getCollection } from "astro:content";
import BaseHead from "../../components/BaseHead.astro";
import Footer from "../../components/Footer.astro";
import Header from "../../components/Header.astro";
import { SITE_TITLE, SITE_DESCRIPTION } from "../../consts";
import { getTechIcon } from "../../utils/techIcons";
import { Icon } from "astro-icon/components";
import BlogHeader from "../../components/BlogHeader.astro";
import BlogHeatmap from "../../components/BlogHeatmap.astro";
import BlogTable from "../../components/BlogTable.astro";
import BlogPreview from "../../components/BlogPreview.astro";

const posts = (await getCollection("blog")).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

// Prepare data for client-side components
const postsData = posts.map((p) => ({
	id: p.id,
	title: p.data.title,
	description: p.data.description,
	pubDate: p.data.pubDate.toISOString(),
	tags: p.data.tags || [],
	complexity: p.data.complexity ?? 0.5,
	readingTime: p.data.readingTime ?? 5,
	slug: p.id,
}));

const totalPosts = posts.length;
const topicsCount = [...new Set(posts.flatMap((p) => p.data.tags || []))]
	.length;
const readingTotal = posts.reduce((s, p) => s + (p.data.readingTime || 5), 0);
---

<!DOCTYPE html>
<html lang="es">
	<head>
		<BaseHead
			title={`Blog — ${SITE_TITLE}`}
			description={SITE_DESCRIPTION}
		/>
	</head>
	<body>
		<Header />
		<main class="blog-main">
			<!-- ═══ HEADER ═══ -->
			<BlogHeader
				totalPosts={totalPosts}
				topicsCount={topicsCount}
				readingTotal={readingTotal}
			/>

			<!-- ═══ ACTIVITY HEATMAP ═══ -->
			<BlogHeatmap postsData={JSON.stringify(postsData)} />

			<!-- ═══ DATA TABLE ═══ -->
			<BlogTable postsData={postsData} />

			<!-- ═══ HOVER PREVIEW ═══ -->
			<BlogPreview />
		</main>
		<Footer />

		<style>
			/* ═══════════ LAYOUT ═══════════ */
			.blog-main {
				width: 100%;
				max-width: 1000px;
				margin: 0 auto;
				padding: 1.5rem 1rem;
				display: flex;
				flex-direction: column;
				gap: 1.2rem;
			}

			/* ═══════════ PANELS ═══════════ */
			.panel {
				background: var(--surface);
				border: 1px solid var(--gray-light);
				border-radius: 14px;
				padding: 1rem 1.2rem;
				box-shadow: var(--box-shadow);
			}

			.panel-header {
				display: flex;
				align-items: center;
				gap: 0.5rem;
				margin-bottom: 0.8rem;
			}

			.panel-dot {
				width: 6px;
				height: 6px;
				border-radius: 50%;
				background: var(--primary);
			}

			.panel-title {
				font-family: "Fira Code", monospace;
				font-size: 0.72rem;
				font-weight: 700;
				color: var(--black);
				text-transform: uppercase;
				letter-spacing: 0.05em;
			}

			@media (max-width: 640px) {
				.heatmap-container {
					grid-template-columns: repeat(26, 1fr);
				}

				.search-input {
					width: 120px;
				}
			}
		</style>
	</body>
</html>
