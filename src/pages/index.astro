---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { SITE_TITLE, SITE_DESCRIPTION } from "../consts";
import { getCollection } from "astro:content";
import HomeBlogCard from "../components/HomeBlogCard.astro";
import NeuralNetworkHero from "../components/NeuralNetworkHero.astro";
import SkillsMatrix from "../components/SkillsMatrix.astro";
import PortfolioGrid from "../components/PortfolioGrid.astro";

const allPosts = await getCollection("blog");
const posts = allPosts
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 3);

const allProjects = await getCollection("projects");
const projects = allProjects
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 4);

// ─── Compute metrics per project ───
const now = new Date();
const projectMetrics = projects.map((p) => {
	const created = new Date(p.data.pubDate);
	const updated = new Date(p.data.updatedDate || p.data.pubDate);
	const daysSinceUpdate = Math.floor(
		(now.getTime() - updated.getTime()) / (1000 * 60 * 60 * 24)
	);
	const ageMonths = Math.floor(
		(now.getTime() - created.getTime()) / (1000 * 60 * 60 * 24 * 30)
	);

	let health: "green" | "yellow" | "red";
	let healthLabel: string;
	if (daysSinceUpdate < 30) {
		health = "green";
		healthLabel = "HEALTHY";
	} else if (daysSinceUpdate < 90) {
		health = "yellow";
		healthLabel = "STALE";
	} else {
		health = "red";
		healthLabel = "DORMANT";
	}

	const uptime =
		daysSinceUpdate < 7
			? "99.9%"
			: daysSinceUpdate < 30
			? "99.5%"
			: daysSinceUpdate < 90
			? "95.2%"
			: "—";

	return {
		...p,
		health,
		healthLabel,
		daysSinceUpdate,
		ageMonths,
		uptime,
	};
});
---

<!DOCTYPE html>
<html lang="es">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main class="dashboard">
			<!-- ═══ HERO: Full-width Neural Network ═══ -->
			<section class="hero-full">
				<NeuralNetworkHero />
			</section>

			<!-- ═══ DASHBOARD SECTIONS (scroll-reveal) ═══ -->
			<div class="dashboard-content">
				<!-- Two-column grid -->
				<div class="dashboard-grid">
					<!-- Left: Skills Matrix -->
					<section class="panel panel-skills reveal">
						<div class="panel-header">
							<span class="panel-dot"></span>
							<h2>Stack Tecnológico</h2>
						</div>
						<SkillsMatrix />
					</section>

					<!-- Right: Latest Blog -->
					<section class="panel panel-blog reveal">
						<div class="panel-header">
							<span class="panel-dot dot-accent"></span>
							<h2>Últimas Reflexiones</h2>
							<a href="/blog" class="panel-link">Ver todo →</a>
						</div>
						<div class="blog-list">
							{
								posts.map((post) => (
									<HomeBlogCard
										post={post}
										ageDays={Math.floor(
											(new Date().getTime() -
												new Date(
													post.data.pubDate
												).getTime()) /
												(1000 * 60 * 60 * 24)
										)}
									/>
								))
							}
						</div>
					</section>
				</div>

				<!-- Projects: full-width -->
				<section class="panel panel-projects reveal">
					<div class="panel-header">
						<span class="panel-dot dot-green"></span>
						<h2>Arquitectura & Modelos</h2>
						<a href="/portfolio" class="panel-link"
							>Ver portafolio →</a
						>
					</div>
					<PortfolioGrid projects={projectMetrics} />
				</section>
			</div>
		</main>
		<Footer />
		<style>
			/* ═══ FULL-WIDTH DASHBOARD ═══ */
			main.dashboard {
				width: 100%;
				max-width: 100%;
				margin: 0;
				padding: 0;
			}

			.dashboard {
				display: flex;
				flex-direction: column;
				gap: 0;
			}

			/* ═══ HERO — FULL VIEWPORT ═══ */
			.hero-full {
				width: 100vw;
				margin-left: calc(-50vw + 50%);
				padding: 0;
				margin-bottom: 0;
			}

			.hero-full :global(.nn-hero) {
				border-radius: 0;
				min-height: 85vh;
				border: none;
				box-shadow: none;
			}

			.hero-full :global(.hero-overlay) {
				min-height: 85vh;
			}

			/* ═══ DASHBOARD CONTENT ═══ */
			.dashboard-content {
				display: flex;
				flex-direction: column;
				gap: 1.5rem;
				padding: 2.5rem 2rem;
				max-width: 1200px;
				margin: 0 auto;
				width: 100%;
			}

			/* ═══ DASHBOARD TWO-COLUMN GRID ═══ */
			.dashboard-grid {
				display: grid;
				grid-template-columns: 1fr 1fr;
				gap: 1.5rem;
			}

			/* ═══ PANELS ═══ */
			.panel {
				background: var(--surface);
				border: 1px solid var(--gray-light);
				border-radius: 16px;
				padding: 1.5rem;
				box-shadow: var(--box-shadow);
			}

			.panel-header {
				display: flex;
				align-items: center;
				gap: 0.6rem;
				margin-bottom: 1.25rem;
				padding-bottom: 0.75rem;
				border-bottom: 1px solid var(--gray-light);
			}

			.panel-dot {
				width: 8px;
				height: 8px;
				border-radius: 50%;
				background: var(--primary);
				flex-shrink: 0;
			}

			.panel-dot.dot-accent {
				background: var(--accent);
			}
			.panel-dot.dot-green {
				background: #28c840;
			}

			.panel-header h2 {
				font-family: "Fira Code", monospace;
				font-size: 0.95rem;
				font-weight: 700;
				margin: 0;
				color: var(--black);
				flex: 1;
			}

			.panel-link {
				font-family: "Fira Code", monospace;
				font-size: 0.72rem;
				color: var(--primary);
				text-decoration: none;
				white-space: nowrap;
				transition: color 0.2s ease;
				border-bottom: none;
			}

			.panel-link:hover {
				color: var(--accent);
				border-bottom: none;
			}

			/* ═══ BLOG LIST ═══ */
			.blog-list {
				display: flex;
				flex-direction: column;
				gap: 1rem;
			}

			/* ═══ SCROLL REVEAL ═══ */
			.reveal {
				opacity: 0;
				transform: translateY(30px);
				transition: opacity 0.7s ease, transform 0.7s ease;
			}

			.reveal.visible {
				opacity: 1;
				transform: translateY(0);
			}

			/* ═══ RESPONSIVE ═══ */
			@media (max-width: 768px) {
				.dashboard-grid {
					grid-template-columns: 1fr;
				}

				.dashboard-content {
					padding: 1.5rem 1rem;
					gap: 1rem;
				}

				.hero-full :global(.nn-hero) {
					min-height: 75vh;
				}

				.hero-full :global(.hero-overlay) {
					min-height: 75vh;
				}
			}
		</style>

		<script>
			// Scroll-reveal observer
			const observer = new IntersectionObserver(
				(entries) => {
					entries.forEach((entry) => {
						if (entry.isIntersecting) {
							entry.target.classList.add("visible");
						}
					});
				},
				{ threshold: 0.1, rootMargin: "0px 0px -50px 0px" }
			);

			document
				.querySelectorAll(".reveal")
				.forEach((el) => observer.observe(el));
		</script>
	</body>
</html>
