---
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import FormattedDate from "../components/FormattedDate.astro";
import Header from "../components/Header.astro";

type Props = CollectionEntry<"blog">["data"];

const { title, description, pubDate, updatedDate, heroImage, tags } =
	Astro.props;
---

<html lang="es">
	<head>
		<BaseHead title={title} description={description} />
	</head>

	<body>
		<Header />
		<main class="blog-post-main">
			<article class="article-panel">
				<!-- Hero image (full-width inside panel) -->
				{
					heroImage && (
						<div class="hero-image">
							<Image
								width={960}
								height={480}
								src={heroImage}
								alt=""
							/>
						</div>
					)
				}

				<!-- Article header -->
				<div class="article-header">
					<div class="article-meta">
						<span class="meta-dot"></span>
						<FormattedDate date={pubDate} />
						{
							updatedDate && (
								<span class="meta-updated">
									· Actualizado{" "}
									<FormattedDate date={updatedDate} />
								</span>
							)
						}
					</div>
					<h1 class="article-title">{title}</h1>
					{
						description && (
							<p class="article-description">{description}</p>
						)
					}
					{
						tags && tags.length > 0 && (
							<div class="article-tags">
								{tags.map((tag) => (
									<span class="article-tag">{tag}</span>
								))}
							</div>
						)
					}
				</div>

				<div class="article-divider"></div>

				<!-- Content -->
				<div class="prose">
					<slot />
				</div>
			</article>
		</main>
		<Footer />
		<style>
			main.blog-post-main {
				width: 100%;
				max-width: 800px;
				margin: 0 auto;
				padding: 1.5rem 1rem;
			}

			.article-panel {
				background: var(--surface);
				border: 1px solid var(--gray-light);
				border-radius: 16px;
				overflow: hidden;
				box-shadow: var(--box-shadow);
			}

			/* ═══ HERO IMAGE ═══ */
			.hero-image {
				width: 100%;
				overflow: hidden;
			}

			.hero-image img {
				width: 100%;
				height: auto;
				display: block;
				object-fit: cover;
			}

			/* ═══ ARTICLE HEADER ═══ */
			.article-header {
				padding: 2rem 2rem 0 2rem;
			}

			.article-meta {
				display: flex;
				align-items: center;
				gap: 0.5rem;
				font-family: "Fira Code", monospace;
				font-size: 0.75rem;
				color: var(--gray);
				margin-bottom: 0.8rem;
			}

			.meta-dot {
				width: 6px;
				height: 6px;
				border-radius: 50%;
				background: var(--primary);
				flex-shrink: 0;
			}

			.meta-updated {
				color: var(--gray);
				font-style: italic;
			}

			.article-title {
				font-family: "Fira Code", monospace;
				font-size: 1.8rem;
				font-weight: 800;
				color: var(--black);
				margin: 0;
				line-height: 1.2;
			}

			.article-description {
				font-size: 0.95rem;
				color: var(--gray);
				margin: 0.5rem 0 0 0;
				line-height: 1.5;
			}

			.article-tags {
				display: flex;
				gap: 0.4rem;
				flex-wrap: wrap;
				margin-top: 0.8rem;
			}

			.article-tag {
				font-family: "Fira Code", monospace;
				font-size: 0.6rem;
				padding: 0.2rem 0.55rem;
				border-radius: 4px;
				background: color-mix(in srgb, var(--primary) 10%, transparent);
				color: var(--primary);
				border: 1px solid
					color-mix(in srgb, var(--primary) 18%, transparent);
				text-transform: uppercase;
			}

			/* ═══ DIVIDER ═══ */
			.article-divider {
				height: 1px;
				background: var(--gray-light);
				margin: 1.5rem 2rem;
			}

			/* ═══ PROSE ═══ */
			.prose {
				padding: 0 2rem 2rem 2rem;
				font-size: 1rem;
				line-height: 1.75;
				color: var(--black);
			}

			.prose :global(h2) {
				font-family: "Fira Code", monospace;
				font-size: 1.3rem;
				font-weight: 700;
				margin-top: 2rem;
				margin-bottom: 0.5rem;
				padding-bottom: 0.3rem;
				border-bottom: 1px solid var(--gray-light);
				color: var(--black);
			}

			.prose :global(h3) {
				font-family: "Fira Code", monospace;
				font-size: 1.1rem;
				font-weight: 700;
				margin-top: 1.5rem;
				margin-bottom: 0.4rem;
				color: var(--black);
			}

			.prose :global(p) {
				margin: 0.8rem 0;
			}

			.prose :global(a) {
				color: var(--primary);
				text-decoration: underline;
				text-underline-offset: 3px;
			}

			.prose :global(a:hover) {
				color: var(--accent);
			}

			.prose :global(code) {
				font-family: "Fira Code", monospace;
				font-size: 0.85em;
				background: color-mix(
					in srgb,
					var(--gray-light) 60%,
					transparent
				);
				padding: 0.15em 0.4em;
				border-radius: 4px;
				border: 1px solid
					color-mix(in srgb, var(--gray-light) 80%, transparent);
			}

			.prose :global(pre) {
				background: var(--gray-dark) !important;
				border: 1px solid var(--gray-light);
				border-radius: 10px;
				padding: 1.2rem;
				overflow-x: auto;
				font-size: 0.82rem;
				margin: 1rem 0;
			}

			.prose :global(pre code) {
				background: none;
				padding: 0;
				border: none;
				font-size: inherit;
			}

			.prose :global(blockquote) {
				border-left: 3px solid var(--primary);
				padding: 0.5rem 1rem;
				margin: 1rem 0;
				background: color-mix(in srgb, var(--primary) 5%, transparent);
				border-radius: 0 8px 8px 0;
				font-style: italic;
				color: var(--gray);
			}

			.prose :global(img) {
				max-width: 100%;
				border-radius: 10px;
				margin: 1rem 0;
				box-shadow: var(--box-shadow);
			}

			.prose :global(ul),
			.prose :global(ol) {
				padding-left: 1.5rem;
			}

			.prose :global(li) {
				margin: 0.3rem 0;
			}

			.prose :global(hr) {
				border: none;
				height: 1px;
				background: var(--gray-light);
				margin: 2rem 0;
			}

			/* ═══ RESPONSIVE ═══ */
			@media (max-width: 640px) {
				.article-header {
					padding: 1.2rem 1.2rem 0;
				}

				.article-title {
					font-size: 1.3rem;
				}

				.article-divider {
					margin: 1rem 1.2rem;
				}

				.prose {
					padding: 0 1.2rem 1.2rem;
				}
			}
		</style>
		<script>
			import mermaid from "mermaid";

			document.addEventListener("DOMContentLoaded", () => {
				const isDark = window.matchMedia(
					"(prefers-color-scheme: dark)"
				).matches;
				const rootStyles = getComputedStyle(document.documentElement);
				const bgColor = rootStyles
					.getPropertyValue("--background")
					.trim();
				const surfaceColor = rootStyles
					.getPropertyValue("--surface")
					.trim();
				const primaryColor = rootStyles
					.getPropertyValue("--primary")
					.trim();
				const accentColor = rootStyles
					.getPropertyValue("--accent")
					.trim();
				const textColor = rootStyles.getPropertyValue("--black").trim();
				const grayColor = rootStyles.getPropertyValue("--gray").trim();
				const grayLightColor = rootStyles
					.getPropertyValue("--gray-light")
					.trim();
				const fontFamily =
					rootStyles.getPropertyValue("font-family").trim() ||
					'"Fira Code", monospace';

				mermaid.initialize({
					startOnLoad: false,
					theme: "base",
					themeVariables: {
						fontFamily: fontFamily,
						primaryColor: surfaceColor,
						primaryTextColor: textColor,
						primaryBorderColor: primaryColor,
						lineColor: grayColor,
						secondaryColor: bgColor,
						tertiaryColor: bgColor,
						mainBkg: surfaceColor,
						nodeBorder: primaryColor,
						clusterBkg: bgColor,
						clusterBorder: grayLightColor,
						defaultLinkColor: accentColor,
						labelTextColor: textColor,
						labelBackground: bgColor,
						edgeLabelBackground: bgColor,
						textColor: textColor,
					},
				});

				const blocks = document.querySelectorAll(
					"pre > code.language-mermaid, pre[data-language='mermaid']"
				);
				blocks.forEach((block) => {
					const pre =
						block.tagName === "PRE" ? block : block.parentElement;
					if (pre) {
						const div = document.createElement("div");
						div.className = "mermaid";
						div.style.display = "flex";
						div.style.justifyContent = "center";
						div.style.margin = "1.5rem 0";
						const lines = pre.querySelectorAll(".line");
						div.textContent =
							lines.length > 0
								? Array.from(lines)
										.map((l) => l.textContent)
										.join("\\n")
								: pre.textContent;
						pre.replaceWith(div);
					}
				});

				mermaid.run({ querySelector: ".mermaid" });
			});
		</script>
	</body>
</html>
