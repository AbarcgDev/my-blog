---
import type { CollectionEntry } from "astro:content";
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import FormattedDate from "../components/FormattedDate.astro";
import Header from "../components/Header.astro";

type Props = CollectionEntry<"projects">["data"];

const {
    title,
    description,
    pubDate,
    updatedDate,
    repoUrl,
    language,
    stars,
    tags,
} = Astro.props;
---

<html lang="es">
    <head>
        <BaseHead title={`${title} — Portafolio`} description={description} />
        <style>
            main {
                width: calc(100% - 2em);
                max-width: 100%;
                margin: 0;
            }

            /* ========== PROJECT HEADER ========== */
            .project-header {
                max-width: 800px;
                margin: 2rem auto;
                padding: 0 1rem;
            }

            .project-back {
                display: inline-flex;
                align-items: center;
                gap: 0.4em;
                font-family: "Fira Code", monospace;
                font-size: 0.85rem;
                color: var(--primary);
                text-decoration: none;
                margin-bottom: 1.5rem;
                transition: all 0.2s ease;
                border-bottom: none;
            }

            .project-back:hover {
                color: var(--accent);
                transform: translateX(-4px);
                border-bottom: none;
            }

            .project-meta-card {
                background: var(--surface);
                border: 1px solid var(--gray-light);
                border-radius: 16px;
                padding: 2rem;
                box-shadow: var(--box-shadow);
            }

            .project-title {
                font-family: "Fira Code", monospace;
                font-size: 2.2rem;
                font-weight: 700;
                margin: 0 0 0.5rem 0;
                color: var(--black);
                line-height: 1.2;
            }

            .project-description {
                font-size: 1.05rem;
                color: var(--gray);
                margin: 0 0 1.5rem 0;
                line-height: 1.6;
            }

            /* Meta row: date, language, stars */
            .project-meta-row {
                display: flex;
                flex-wrap: wrap;
                gap: 1rem;
                align-items: center;
                margin-bottom: 1.25rem;
                padding-bottom: 1.25rem;
                border-bottom: 1px solid var(--gray-light);
            }

            .meta-badge {
                display: inline-flex;
                align-items: center;
                gap: 0.35em;
                font-family: "Fira Code", monospace;
                font-size: 0.78rem;
                padding: 0.3em 0.75em;
                border-radius: 8px;
                background: color-mix(in srgb, var(--primary) 8%, transparent);
                color: var(--gray-dark);
                border: 1px solid
                    color-mix(in srgb, var(--primary) 15%, transparent);
            }

            .meta-badge.lang {
                background: color-mix(in srgb, var(--accent) 10%, transparent);
                border-color: color-mix(
                    in srgb,
                    var(--accent) 18%,
                    transparent
                );
                color: var(--accent);
            }

            .meta-badge.stars {
                background: color-mix(in srgb, #f5a623 12%, transparent);
                border-color: color-mix(in srgb, #f5a623 20%, transparent);
            }

            /* Tags */
            .project-tags {
                display: flex;
                flex-wrap: wrap;
                gap: 0.5rem;
                margin-bottom: 1.5rem;
            }

            .project-tag {
                font-family: "Fira Code", monospace;
                font-size: 0.7rem;
                font-weight: 600;
                padding: 0.25em 0.75em;
                border-radius: 6px;
                background: color-mix(in srgb, var(--primary) 10%, transparent);
                color: var(--primary-dark);
                border: 1px solid
                    color-mix(in srgb, var(--primary) 15%, transparent);
                text-transform: uppercase;
                letter-spacing: 0.03em;
            }

            @media (prefers-color-scheme: dark) {
                .project-tag {
                    color: var(--primary);
                }
                .meta-badge {
                    color: var(--primary);
                }
            }

            /* GitHub link button */
            .repo-link {
                display: inline-flex;
                align-items: center;
                gap: 0.5em;
                font-family: "Fira Code", monospace;
                font-size: 0.85rem;
                font-weight: 600;
                padding: 0.65em 1.5em;
                border-radius: 10px;
                background: var(--gray-dark);
                color: #ffffff;
                text-decoration: none;
                border: 1px solid transparent;
                transition: all 0.25s ease;
            }

            .repo-link:hover {
                background: var(--primary-dark);
                border-color: var(--primary);
                transform: translateY(-2px);
                box-shadow: 0 8px 20px -8px color-mix(in srgb, var(--primary)
                            30%, transparent);
            }

            .repo-link svg {
                width: 18px;
                height: 18px;
                fill: currentColor;
            }

            /* ========== README CONTENT ========== */
            .prose {
                width: 800px;
                max-width: calc(100% - 2em);
                margin: 2rem auto;
                padding: 1em;
                color: var(--black);
                line-height: 1.8;
            }

            .prose h1,
            .prose h2,
            .prose h3 {
                color: var(--black);
                margin-top: 2rem;
            }

            .prose h1 {
                font-size: 1.8rem;
            }
            .prose h2 {
                font-size: 1.4rem;
                padding-bottom: 0.3em;
                border-bottom: 1px solid var(--gray-light);
            }

            .prose img {
                border-radius: 8px;
                box-shadow: var(--box-shadow);
            }

            .prose a {
                color: var(--primary);
            }

            .prose a:hover {
                color: var(--accent);
            }

            @media (max-width: 720px) {
                .project-title {
                    font-size: 1.5rem;
                }
                .project-meta-card {
                    padding: 1.25rem;
                }
                .project-meta-row {
                    gap: 0.5rem;
                }
            }
        </style>
    </head>

    <body>
        <Header />
        <main>
            <div class="project-header">
                <a href="/portfolio" class="project-back">← Portafolio</a>

                <div class="project-meta-card">
                    <h1 class="project-title">{title}</h1>
                    <p class="project-description">{description}</p>

                    <div class="project-meta-row">
                        <span class="meta-badge">
                            📅 <FormattedDate date={pubDate} />
                        </span>
                        {
                            updatedDate && (
                                <span class="meta-badge">
                                    🔄 <FormattedDate date={updatedDate} />
                                </span>
                            )
                        }
                        {
                            language && language !== "N/A" && (
                                <span class="meta-badge lang">{language}</span>
                            )
                        }
                        {
                            stars > 0 && (
                                <span class="meta-badge stars">⭐ {stars}</span>
                            )
                        }
                    </div>

                    {
                        tags.length > 0 && (
                            <div class="project-tags">
                                {tags.map((tag) => (
                                    <span class="project-tag">{tag}</span>
                                ))}
                            </div>
                        )
                    }

                    <a
                        href={repoUrl}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="repo-link"
                    >
                        <svg viewBox="0 0 16 16" aria-hidden="true">
                            <path
                                d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"
                            ></path>
                        </svg>
                        Ver en GitHub
                    </a>
                </div>
            </div>

            <div class="prose">
                <slot />
            </div>
        </main>
        <Footer />
    </body>
</html>
