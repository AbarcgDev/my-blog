---
import type { CollectionEntry } from "astro:content";
import { Icon } from "astro-icon/components";
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import FormattedDate from "../components/FormattedDate.astro";
import Header from "../components/Header.astro";
import SidebarToggle from "../components/SidebarToggle.astro";
import { getTechIcon } from "../utils/techIcons";

type Props = CollectionEntry<"projects">["data"] & {
    headings?: { depth: number; slug: string; text: string }[];
};

const {
    title,
    description,
    pubDate,
    updatedDate,
    repoUrl,
    language,
    stars,
    tags,
    headings = [],
} = Astro.props;
---

<html lang="es">
    <head>
        <BaseHead title={`${title} — Portafolio`} description={description} />
    </head>

    <body class="grid-app-body">
        <Header />
        <SidebarToggle />
        <main class="grid-app-main project-post-main">
            <div class="post-layout">
                <!-- ═══ SIDEBAR ═══ -->
                <aside class="post-sidebar">
                    <a href="/portfolio" class="back-button">
                        ← Volver al Portafolio
                    </a>

                    <div class="sidebar-block author-block">
                        <div class="author-info">
                            <strong>Alvaro Abarca</strong>
                            <span>Data & AI Enthusiast</span>
                        </div>
                    </div>

                    <div class="sidebar-block bmac-block">
                        <a
                            href="https://buymeacoffee.com/"
                            target="_blank"
                            rel="noopener noreferrer"
                            class="bmac-button"
                        >
                            <svg
                                viewBox="0 0 16 16"
                                width="16"
                                height="16"
                                aria-hidden="true"
                                ><path
                                    fill="currentColor"
                                    d="M3 2v4.5A4.5 4.5 0 0 0 7.5 11h2.52a4.48 4.48 0 0 0 4.17-2.92A2.5 2.5 0 0 0 13 4.5h-1a1 1 0 0 0-1-1V2H3zm8 7.5H7.5A3.5 3.5 0 0 1 4 6.5V3h6v6.5zM12 4.5a1.5 1.5 0 0 1 1.5 1.5c0 .64-.4 1.2-1 1.42V4.5h-.5zM2 13v1h11v-1H2z"
                                ></path>
                            </svg>
                            Buy me a coffee
                        </a>
                    </div>

                    <div class="sidebar-block meta-block">
                        <div class="meta-item">
                            <span class="meta-label">Publicado</span>
                            <FormattedDate date={pubDate} />
                        </div>
                        {
                            updatedDate && (
                                <div class="meta-item">
                                    <span class="meta-label">Actualizado</span>
                                    <FormattedDate date={updatedDate} />
                                </div>
                            )
                        }
                        {
                            language && language !== "N/A" && (
                                <div class="meta-item">
                                    <span class="meta-label">Lenguaje</span>
                                    <span class="meta-lang">{language}</span>
                                </div>
                            )
                        }
                        {
                            stars > 0 && (
                                <div class="meta-item">
                                    <span class="meta-label">Stars</span>
                                    <span>⭐ {stars}</span>
                                </div>
                            )
                        }
                        {
                            tags && tags.length > 0 && (
                                <div class="meta-tags">
                                    {tags.map((tag: string) => (
                                        <span class="tech-tag" title={tag}>
                                            <Icon name={getTechIcon(tag)} />
                                        </span>
                                    ))}
                                </div>
                            )
                        }
                    </div>

                    {
                        repoUrl && (
                            <a
                                href={repoUrl}
                                target="_blank"
                                rel="noopener noreferrer"
                                class="repo-link"
                            >
                                <svg
                                    viewBox="0 0 16 16"
                                    width="18"
                                    height="18"
                                    aria-hidden="true"
                                >
                                    <path
                                        fill="currentColor"
                                        d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"
                                    />
                                </svg>
                                Ver en GitHub
                            </a>
                        )
                    }

                    {
                        headings.length > 0 && (
                            <div class="sidebar-block toc-block">
                                <h3 class="toc-title">Índice</h3>
                                <ul class="toc-list">
                                    {headings.map((h: any) => (
                                        <li class={`toc-depth-${h.depth}`}>
                                            <a href={`#${h.slug}`}>{h.text}</a>
                                        </li>
                                    ))}
                                </ul>
                            </div>
                        )
                    }
                </aside>

                <!-- ═══ CONTENT ═══ -->
                <div class="post-content-wrapper">
                    <article class="article-panel">
                        <!-- Article header -->
                        <div class="article-header">
                            <h1 class="article-title">{title}</h1>
                            {
                                description && (
                                    <p class="article-description">
                                        {description}
                                    </p>
                                )
                            }
                        </div>

                        <div class="article-divider"></div>

                        <!-- Content -->
                        <div class="prose">
                            <slot />
                        </div>
                    </article>
                    <div class="app-footer-wrapper">
                        <Footer />
                    </div>
                </div>
            </div>
        </main>
        <style>
            /* ═══ GLOBAL APP LAYOUT ═══ */
            :global(.grid-app-body) {
                height: 100vh;
                overflow: hidden;
                display: flex;
                flex-direction: column;
                background: var(--background);
                margin: 0;
            }

            :global(.grid-app-body) > * {
                flex-shrink: 0;
            }

            .grid-app-main {
                flex: 1;
                width: 100%;
                margin: 0 auto;
                display: flex;
                flex-direction: column;
                overflow: hidden;
                padding: 0 1rem;
            }

            /* ═══ TWO-COLUMN POST LAYOUT ═══ */
            .post-layout {
                display: grid;
                grid-template-columns: 320px 1fr;
                gap: 1.5rem;
                flex: 1;
                overflow: hidden;
                padding-bottom: 2rem;
                width: 100%;
            }

            .post-sidebar {
                display: flex;
                flex-direction: column;
                gap: 1.5rem;
                height: 100%;
                overflow-y: auto;
                padding-right: 0.5rem;
                scrollbar-width: none;
                -ms-overflow-style: none;
            }
            .post-sidebar::-webkit-scrollbar {
                display: none;
            }

            .post-content-wrapper {
                display: flex;
                flex-direction: column;
                flex: 1;
                overflow: hidden;
                padding-right: 0.5rem;
            }

            .app-footer-wrapper {
                margin-top: 3rem;
                border-radius: 14px;
                overflow: hidden;
            }

            /* ═══ SIDEBAR BLOCKS ═══ */
            .back-button {
                display: inline-flex;
                align-items: center;
                font-family: "Fira Code", monospace;
                font-size: 0.85rem;
                font-weight: 700;
                color: var(--gray);
                text-decoration: none;
                transition: color 0.2s ease;
                padding: 0.5rem 0;
            }
            .back-button:hover {
                color: var(--primary);
            }

            .sidebar-block {
                background: var(--surface);
                border: 1px solid var(--gray-light);
                border-radius: 14px;
                padding: 1.2rem;
                box-shadow: var(--box-shadow);
            }

            .author-info strong {
                display: block;
                font-family: "Fira Code", monospace;
                font-size: 0.9rem;
                color: var(--black);
            }
            .author-info span {
                display: block;
                font-family: "Fira Code", monospace;
                font-size: 0.75rem;
                color: var(--gray);
                margin-top: 0.2rem;
            }

            .bmac-block {
                padding: 0;
                border: none;
                background: none;
                box-shadow: none;
            }
            .bmac-button {
                display: flex;
                align-items: center;
                justify-content: center;
                gap: 0.6rem;
                width: 100%;
                padding: 0.8rem 1rem;
                border-radius: 14px;
                background: #ffdd00;
                color: #000000;
                font-family: "Fira Code", monospace;
                font-size: 0.85rem;
                font-weight: 800;
                text-decoration: none;
                transition: transform 0.2s ease, box-shadow 0.2s ease;
            }
            .bmac-button:hover {
                transform: translateY(-2px);
                box-shadow: 0 4px 12px rgba(255, 221, 0, 0.4);
            }

            .meta-item {
                margin-bottom: 0.8rem;
            }
            .meta-item:last-child {
                margin-bottom: 0;
            }
            .meta-label {
                display: block;
                font-family: "Fira Code", monospace;
                font-size: 0.65rem;
                color: var(--gray);
                text-transform: uppercase;
                letter-spacing: 0.05em;
                margin-bottom: 0.2rem;
            }
            .meta-lang {
                font-family: "Fira Code", monospace;
                font-size: 0.85rem;
                font-weight: 600;
                color: var(--accent);
            }
            .meta-tags {
                display: flex;
                flex-wrap: wrap;
                gap: 0.4rem;
                margin-top: 1rem;
            }
            .meta-tag,
            .tech-tag {
                font-size: 0;
                display: inline-flex;
                align-items: center;
                justify-content: center;
                transition: transform 0.2s ease;
            }
            .tech-tag:hover {
                transform: translateY(-2px);
            }
            .tech-tag [data-icon] {
                font-size: 1.5rem;
            }

            .repo-link {
                display: flex;
                align-items: center;
                justify-content: center;
                gap: 0.5em;
                font-family: "Fira Code", monospace;
                font-size: 0.85rem;
                font-weight: 600;
                padding: 0.65em 1.5em;
                border-radius: 14px;
                background: var(--gray-dark);
                color: #ffffff;
                text-decoration: none;
                border: 1px solid transparent;
                transition: all 0.25s ease;
            }
            .repo-link:hover {
                background: var(--primary-dark);
                border-color: var(--primary);
                transform: translateY(-2px);
                box-shadow: 0 8px 20px -8px color-mix(in srgb, var(--primary)
                            30%, transparent);
            }

            .toc-title {
                font-family: "Fira Code", monospace;
                font-size: 0.8rem;
                font-weight: 700;
                color: var(--black);
                text-transform: uppercase;
                letter-spacing: 0.05em;
                margin: 0 0 1rem 0;
            }
            .toc-list {
                list-style: none;
                padding: 0;
                margin: 0;
            }
            .toc-list li {
                margin-bottom: 0.6rem;
            }
            .toc-list a {
                text-decoration: none;
                color: var(--gray);
                font-size: 0.85rem;
                transition: color 0.2s ease;
            }
            .toc-list a:hover {
                color: var(--primary);
            }
            .toc-depth-2 {
                padding-left: 0;
                font-weight: 500;
            }
            .toc-depth-3 {
                padding-left: 1rem;
                font-size: 0.8rem;
            }
            .toc-depth-4 {
                padding-left: 2rem;
                font-size: 0.75rem;
            }

            /* ═══ ARTICLE PANEL ═══ */
            .article-panel {
                background: var(--surface);
                border: 1px solid var(--gray-light);
                border-radius: 16px;
                overflow: hidden;
                box-shadow: var(--box-shadow);
                display: flex;
                flex-direction: column;
                flex: 1;
                min-height: 0;
            }

            .article-header {
                padding: 2rem 2rem 0 2rem;
            }

            .article-title {
                font-family: "Fira Code", monospace;
                font-size: 1.8rem;
                font-weight: 800;
                color: var(--black);
                margin: 0;
                line-height: 1.2;
            }

            .article-description {
                font-size: 0.95rem;
                color: var(--gray);
                margin: 0.5rem 0 0 0;
                line-height: 1.5;
            }

            .article-divider {
                height: 1px;
                background: var(--gray-light);
                margin: 1.5rem 2rem;
            }

            /* ═══ PROSE ═══ */
            .prose {
                padding: 0 2rem 2rem 2rem;
                font-size: 1rem;
                line-height: 1.75;
                color: var(--black);
                flex: 1;
                overflow-y: auto;
                min-height: 0;
            }
            .prose::-webkit-scrollbar {
                width: 6px;
            }
            .prose::-webkit-scrollbar-thumb {
                background-color: var(--primary);
                border-radius: 10px;
            }

            .prose :global(h1) {
                font-family: "Fira Code", monospace;
                font-size: 1.5rem;
                font-weight: 700;
                margin-top: 2rem;
                color: var(--black);
            }
            .prose :global(h2) {
                font-family: "Fira Code", monospace;
                font-size: 1.3rem;
                font-weight: 700;
                margin-top: 2rem;
                margin-bottom: 0.5rem;
                padding-bottom: 0.3rem;
                border-bottom: 1px solid var(--gray-light);
                color: var(--black);
            }

            .prose :global(h3) {
                font-family: "Fira Code", monospace;
                font-size: 1.1rem;
                font-weight: 700;
                margin-top: 1.5rem;
                margin-bottom: 0.4rem;
                color: var(--black);
            }

            .prose :global(p) {
                margin: 0.8rem 0;
            }

            .prose :global(a) {
                color: var(--primary);
                text-decoration: underline;
                text-underline-offset: 3px;
            }
            .prose :global(a:hover) {
                color: var(--accent);
            }

            .prose :global(code) {
                font-family: "Fira Code", monospace;
                font-size: 0.85em;
                background: color-mix(
                    in srgb,
                    var(--gray-light) 60%,
                    transparent
                );
                padding: 0.15em 0.4em;
                border-radius: 4px;
                border: 1px solid
                    color-mix(in srgb, var(--gray-light) 80%, transparent);
            }

            .prose :global(pre) {
                background: var(--gray-dark) !important;
                border: 1px solid var(--gray-light);
                border-radius: 10px;
                padding: 1.2rem;
                overflow-x: auto;
                font-size: 0.82rem;
                margin: 1rem 0;
            }

            .prose :global(pre code) {
                background: none;
                padding: 0;
                border: none;
                font-size: inherit;
            }

            .prose :global(blockquote) {
                border-left: 3px solid var(--primary);
                padding: 0.5rem 1rem;
                margin: 1rem 0;
                background: color-mix(in srgb, var(--primary) 5%, transparent);
                border-radius: 0 8px 8px 0;
                font-style: italic;
                color: var(--gray);
            }

            .prose :global(img) {
                max-width: 100%;
                border-radius: 10px;
                margin: 1rem 0;
                box-shadow: var(--box-shadow);
            }

            .prose :global(ul),
            .prose :global(ol) {
                padding-left: 1.5rem;
            }
            .prose :global(li) {
                margin: 0.3rem 0;
            }
            .prose :global(hr) {
                border: none;
                height: 1px;
                background: var(--gray-light);
                margin: 2rem 0;
            }

            /* ═══ RESPONSIVE ═══ */
            @media (max-width: 900px) {
                .post-layout {
                    grid-template-columns: 1fr;
                    overflow-y: auto;
                    padding-right: 0.5rem;
                }
                .post-layout::-webkit-scrollbar {
                    width: 6px;
                }
                .post-layout::-webkit-scrollbar-thumb {
                    background-color: var(--primary);
                    border-radius: 10px;
                }

                .post-content-wrapper {
                    overflow-y: visible;
                    padding-right: 0;
                }
            }

            @media (max-width: 640px) {
                .article-header {
                    padding: 1.2rem 1.2rem 0;
                }
                .article-title {
                    font-size: 1.3rem;
                }
                .article-divider {
                    margin: 1rem 1.2rem;
                }
                .prose {
                    padding: 0 1.2rem 1.2rem;
                }
            }
        </style>
        <script>
            import mermaid from "mermaid";

            document.addEventListener("DOMContentLoaded", () => {
                const rootStyles = getComputedStyle(document.documentElement);
                const bgColor = rootStyles
                    .getPropertyValue("--background")
                    .trim();
                const surfaceColor = rootStyles
                    .getPropertyValue("--surface")
                    .trim();
                const primaryColor = rootStyles
                    .getPropertyValue("--primary")
                    .trim();
                const accentColor = rootStyles
                    .getPropertyValue("--accent")
                    .trim();
                const textColor = rootStyles.getPropertyValue("--black").trim();
                const grayColor = rootStyles.getPropertyValue("--gray").trim();
                const grayLightColor = rootStyles
                    .getPropertyValue("--gray-light")
                    .trim();
                const fontFamily =
                    rootStyles.getPropertyValue("font-family").trim() ||
                    '"Fira Code", monospace';

                mermaid.initialize({
                    startOnLoad: false,
                    theme: "base",
                    themeVariables: {
                        fontFamily: fontFamily,
                        primaryColor: surfaceColor,
                        primaryTextColor: textColor,
                        primaryBorderColor: primaryColor,
                        lineColor: grayColor,
                        secondaryColor: bgColor,
                        tertiaryColor: bgColor,
                        mainBkg: surfaceColor,
                        nodeBorder: primaryColor,
                        clusterBkg: bgColor,
                        clusterBorder: grayLightColor,
                        defaultLinkColor: accentColor,
                        labelTextColor: textColor,
                        labelBackground: bgColor,
                        edgeLabelBackground: bgColor,
                        textColor: textColor,
                    },
                });
                const blocks = document.querySelectorAll(
                    "pre > code.language-mermaid, pre[data-language='mermaid']"
                );
                blocks.forEach((block) => {
                    const pre =
                        block.tagName === "PRE" ? block : block.parentElement;
                    if (pre) {
                        const div = document.createElement("div");
                        div.className = "mermaid";
                        div.style.display = "flex";
                        div.style.justifyContent = "center";
                        div.style.margin = "1.5rem 0";
                        const lines = pre.querySelectorAll(".line");
                        div.textContent =
                            lines.length > 0
                                ? Array.from(lines)
                                      .map((l) => l.textContent)
                                      .join("\n")
                                : pre.textContent;
                        pre.replaceWith(div);
                    }
                });

                mermaid.run({ querySelector: ".mermaid" });
            });
        </script>
    </body>
</html>
